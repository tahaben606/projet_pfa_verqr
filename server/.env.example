PORT=4000
NODE_ENV=development

# Supabase → Project Settings → API (never commit real values to .env.example)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Same as client VITE_SUPABASE_ANON_KEY: legacy anon JWT (starts with eyJ…), not sb_publishable_*
SUPABASE_ANON_KEY=your_anon_key
# Legacy service_role JWT for server-only use, not sb_secret_*
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional — not used for auth anymore (tokens validated via auth.getUser).
# SUPABASE_JWT_SECRET=

# Public base URL of the React app (used in QR codes)
PUBLIC_APP_URL=http://localhost:5173



CORS_ORIGIN=http://localhost:5173
