{
  "installCommand": "rm -rf node_modules client/node_modules server/node_modules && npm ci",
  "buildCommand": "npm run build -w verqr-client",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
