{
  "installCommand": "rm -rf node_modules client/node_modules server/node_modules && npm ci --include=dev",
  "buildCommand": "npm exec -w verqr-client -- vite build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
