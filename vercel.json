{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "server/src/vercel.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/src/vercel.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
